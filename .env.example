# Database credentials — copy to .env and fill in real values
DB_HOST=localhost
DB_NAME=investments
DB_USER=your_db_user
DB_PASS=your_strong_password_here
DB_CHARSET=utf8mb4

# MCP server (python/mcp_server.py) — optional overrides
# MCP_HOST=127.0.0.1   # bind address; 127.0.0.1 means only reachable via nginx proxy
# MCP_PORT=8765        # internal port; exposed publicly via nginx reverse proxy
